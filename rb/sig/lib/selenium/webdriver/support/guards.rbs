class Selenium::WebDriver::Support::Guards
  def initialize: (RSpec::Core::Example, ?bug_tracker: String, ?conditions: nil) -> void

  def collect_example_guards: () -> Array[untyped]

  def add_condition: (Symbol, ?Symbol) -> void
                   | (Symbol, ?nil) -> void
                   | (Symbol, ?bool) -> void

  def disposition: () -> nil
                 | () -> Array[untyped]

  def skipping_guard: () -> nil

  def satisfied?: (Selenium::WebDriver::Support::Guards::Guard) -> bool

  def pending_guard: () -> nil
                   | () -> Selenium::WebDriver::Support::Guards::Guard
end
